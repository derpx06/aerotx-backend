DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/transactions
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/transactions
REDIS_URL=redis://redis:6379/0
UPLOAD_DIR=/data/uploads

# Amazon Bedrock / AWS credentials
# Alternatively, attach an IAM role to your compute and omit these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Bedrock model ID — must be enabled in your AWS account under Model Access.
# Options:
#   amazon.nova-micro-v1:0        (cheapest, always available)
#   amazon.nova-lite-v1:0         (better reasoning, still affordable)
#   anthropic.claude-3-haiku-20240307-v1:0  (highest quality, requires model access request)
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
